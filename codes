<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <div class="wrapper">
      <section class="screen">0</section>
      <section class="calc-btns">
        <div class="calc-btn-row">
          <button class="calc-btn double">c</button>
          <button class="calc-btn">&larr;</button>
          <button class="calc-btn">&divide;</button>
        </div>

        <div class="calc-btn-row">
          <button class="calc-btn">7</button>
          <button class="calc-btn">8</button>
          <button class="calc-btn">9</button>
          <button class="calc-btn">&times;</button>
        </div>

        <div class="calc-btn-row">
          <button class="calc-btn">4</button>
          <button class="calc-btn">5</button>
          <button class="calc-btn">6</button>
          <button class="calc-btn">&minus;</button>
        </div>

        <div class="calc-btn-row">
          <button class="calc-btn">1</button>
          <button class="calc-btn">2</button>
          <button class="calc-btn">3</button>
          <button class="calc-btn">&plus;</button>
        </div>

        <div class="calc-btn-row">
          <button class="calc-btn triple">0</button>
          <button class="calc-btn">&equals;</button>
        </div>
      </section>
    </div>

    <!--  -->
    <script src="script.js"></script>
  </body>
</html>

html {
  box-sizing: border-box;
  height: 100%;
}
*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}
body {
  align-items: center;
  background: linear-gradient(230deg, #c2e59c, #64b3f4, #c2e59c);
  display: flex;
  font-family: sans-serif;
  height: inherit;
  justify-content: center;
}
.wrapper {
  backdrop-filter: blur(5.5px);
  -webkit-backdrop-filter: blur(5.5px);
  border-radius: 15%;
  box-shadow: 0 4px 30px rgba(35, 35, 35, 0.32);
  color: #232323;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  background: rgba(255, 255, 255, 0.34);
  flex-basis: 400px;
  height: 540px;
  padding: 20px 35px;
}
/*  */
.screen {
  backdrop-filter: blur(5.5px);
  -webkit-backdrop-filter: blur(5.5px);
  background: rgba(255, 255, 255, 0.75);
  border: 1px solid rgba(255, 255, 255, 0.01);
  border-radius: 15px;
  box-shadow: 0 4px 30px rgba(35, 35, 35, 0.2);
  color: #232323;
  font-size: 35px;
  overflow: auto;
  padding: 20px;
  text-align: right;
  width: 325px;
}
/*  */
.calc-btn-row {
  display: flex;
  justify-content: space-between;
  margin: 5% 0;
}
.calc-btn {
  backdrop-filter: blur(5.5px);
  -webkit-backdrop-filter: blur(5.5px);
  background: rgba(255, 255, 255, 0.75);
  border: 1px solid rgba(255, 255, 255, 0.01);
  border-radius: 15px;
  box-shadow: 0 4px 30px rgba(35, 35, 35, 0.1);
  color: #232323;
  flex-basis: 20%;
  font-family: inherit;
  font-size: 23px;
  height: 65px;
}
.calc-btn:last-child {
  backdrop-filter: blur(5.5px);
  -webkit-backdrop-filter: blur(5.5px);
  background: rgba(255, 255, 255, 0.75);
  border-radius: 15px;
  color: #ffff;
  background: #4b4649;
}
.calc-btn:last-child:hover {
  background: inherit;
  color: inherit;
}
.calc-btn:hover {
  background: inherit;
}
.calc-btn:active {
  background-color: #1fbedd;
}
.double {
  flex-basis: 47%;
}
.triple {
  flex-basis: 73%;
}


