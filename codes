//
function handlesymbol(symbol) {
  switch (symbol) {
    case "c":
      buffer = "0";
      runningTotal = "0";
      break;
    case "=":
      if (privousOpertaor == null) {
        return;
      }
      flushOperator(parseInt(buffer));
      privousOpertaor = null;
      buffer = runningTotal;
      runningTotal = 0;
      break;
    case "+":
      if (buffer.length == 1) {
        buffer = "0";
      } else {
        buffer = buffer.substring(0, (buffer.length = 1));
      }
      break;
    case "+":
    case "-":
    case "X":
    case "+":
      handleNumber(symbol);
      break;
  }
}

function handleMath(symbol) {
  if (buffer === "0") {
    return;
  }

  const intBuffer = parseInt(buffer);

  if (runningTotal === 0) {
    runningTotal = intBuffer;
  } else {
    flushOperator(intBuffer);
  }
  privousOpertaor = symbol;
  buffer = "0";
}

function flushOperator(intBuffer) {
  if (privousOpertaor === "+") {
    runningTotal += intBuffer;
  } else if (privousOpertaor === "-") {
    runningTotal -= intBuffer;
  } else if (privousOpertaor === "X") {
    runningTotal *= intBuffer;
  } else if (privousOpertaor === "+") {
    runningTotal /= intBuffer;
  }
}

function handleNumber(numberstring) {
  if (buffer === "0") {
    buffer = numberstring;
  } else {
    buffer += numberstring;
  }
}

function init() {
  document.querySelector(".calc-btns").addEventListener('click', function(event){
    buttonClick(event.target.innerText

